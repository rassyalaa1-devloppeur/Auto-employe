{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "name": "gestion-employes",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Application desktop de gestion des employes",
  "author": "Alaa",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "php artisan serve",
    "vite": "vite",
    "electron": "wait-on http://127.0.0.1:8000 && electron .",
    "desktop": "concurrently -k \"npm run serve\" \"npm run vite\" \"npm run electron\"",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.alaa.gestionemployes",
    "productName": "Gestion Employes",
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "portable-php",
        "to": "php"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "axios": "^1.11.0",
    "concurrently": "^9.0.1",
    "electron": "^37.2.6",
    "electron-builder": "^24.13.3",
    "laravel-vite-plugin": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.7",
    "wait-on": "^8.0.3"
  }
}